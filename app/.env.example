# ── Environment ────────────────────────────────────────────────
# test | production
APP_ENV=test
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────
# Leave empty to use embedded PGlite (zero-setup dev/test).
# Set to a Supabase/Postgres URL for staging/production.
DATABASE_URL=
# Directory for the embedded PGlite database files
PGLITE_DIR=./.data/pglite

# ── Auth ───────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Email ──────────────────────────────────────────────────────
# console = log only (dev). Anything else = send via the provider chain:
# Brevo first (300/day free), then Resend (100/day free) as fallback.
EMAIL_PROVIDER=live
# Brevo (recommended primary): brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
# Resend (automatic fallback if Brevo fails)
RESEND_API_KEY=
# From-address. Must be a VERIFIED sender in Brevo (Settings → Senders).
# onboarding@resend.dev only works for the Resend fallback.
EMAIL_FROM=Pragati <pragati.management@gmail.com>
RESEND_FROM_EMAIL=Pragati <onboarding@resend.dev>
# In test mode, ALL outbound email is redirected here:
TEST_EMAIL_OVERRIDE=sayantankundu93@gmail.com

# ── Payments ───────────────────────────────────────────────────
# test = simulated Square + simulated Zelle verification helpers
# live = real Square API (requires keys below)
PAYMENTS_MODE=test
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=test-signature-key
SQUARE_ENV=sandbox

# ── File storage (production) ──────────────────────────────────
# Vercel Blob — required on Vercel for photo + magazine PDF uploads.
# Created automatically when you connect a Blob store to the project
# (Vercel dashboard → Storage → Blob). Leave empty locally: files are
# written to public/media and public/magazines instead.
BLOB_READ_WRITE_TOKEN=

# ── Cron (production) ──────────────────────────────────────────
# Optional shared secret for /api/cron/sweep. If set, Vercel Cron sends it
# automatically as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=
